# =============================================================================
# Lumenform Studio — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Do NOT commit .env.local to version control.
# =============================================================================

# --- General ---
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Database (PostgreSQL, no ORM) ---
DATABASE_URL=postgresql://user:password@localhost:5432/lumenform

# --- Shopify Storefront API ---
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2024-10

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Auth.js / NextAuth v5 ---
# AUTH_URL is inferred from NEXTAUTH_URL or VERCEL_URL in production.
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=generate-a-random-secret-here

# --- OAuth Providers (optional, add when ready) ---
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=

# --- Email Magic Link (SMTP) ---
# Required for email magic link authentication in production.
# In development, if these are not set, the magic link URL will be
# logged to the console instead of being emailed.
#
# Recommended providers: Resend (resend.com), SendGrid, AWS SES,
# or any SMTP-compatible service.
#
# Example for Resend:
#   EMAIL_SERVER_HOST=smtp.resend.com
#   EMAIL_SERVER_PORT=465
#   EMAIL_SERVER_USER=resend
#   EMAIL_SERVER_PASSWORD=re_xxxxxxxxxxxx
#   EMAIL_FROM=Lumenform Studio <noreply@yourdomain.com>
#
# Example for SendGrid:
#   EMAIL_SERVER_HOST=smtp.sendgrid.net
#   EMAIL_SERVER_PORT=465
#   EMAIL_SERVER_USER=apikey
#   EMAIL_SERVER_PASSWORD=SG.xxxxxxxxxxxx
#   EMAIL_FROM=Lumenform Studio <noreply@yourdomain.com>
#
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=Lumenform Studio <noreply@lumenform.studio>

# --- Admin ---
ADMIN_EMAILS=admin@example.com
